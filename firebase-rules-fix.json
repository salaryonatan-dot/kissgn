{
  "rules": {
    // ── Global indexes (per-user, per-username) ──────────────────────────────
    "user_tenants": {
      "$uid": {
        // Owner can read/write their own tenant mapping
        ".read":  "auth !== null && auth.uid === $uid",
        ".write": "auth !== null && auth.uid === $uid"
      }
    },
    "user_active_biz": {
      "$uid": {
        ".read":  "auth !== null && auth.uid === $uid",
        ".write": "auth !== null && auth.uid === $uid"
      }
    },
    "username_index": {
      "$username": {
        // Anyone authenticated can read (for login lookup)
        ".read":  "auth !== null",
        // Can write if: (a) doesn't exist yet, OR (b) the email matches current user
        ".write": "auth !== null && (!data.exists() || data.child('email').val() === auth.token.email)"
      }
    },

    // ── Tenant data ──────────────────────────────────────────────────────────
    "tenants": {
      "$tenantId": {
        // ── BOOTSTRAP RULE: allow creating a NEW tenant ──────────────────────
        // A logged-in user can write to members/{their-uid} ONLY if
        // the tenant doesn't have ANY members yet (= brand new tenant)
        // This solves the chicken-and-egg problem!
        "members": {
          "$uid": {
            ".read":  "auth !== null && auth.uid === $uid",
            ".write": "auth !== null && auth.uid === $uid && (
              !data.parent().exists()
              || data.parent().child(auth.uid).exists()
              || root.child('tenants').child($tenantId).child('roles').child(auth.uid).val() === 'super_owner'
              || root.child('tenants').child($tenantId).child('roles').child(auth.uid).val() === 'owner'
            )"
          }
        },
        "roles": {
          "$uid": {
            ".read":  "auth !== null && (
              auth.uid === $uid
              || root.child('tenants').child($tenantId).child('members').child(auth.uid).exists()
            )",
            // Can write own role if: (a) no roles exist yet (bootstrap), OR
            // (b) writer is super_owner/owner of this tenant
            ".write": "auth !== null && (
              (auth.uid === $uid && !data.parent().exists())
              || root.child('tenants').child($tenantId).child('roles').child(auth.uid).val() === 'super_owner'
              || (root.child('tenants').child($tenantId).child('roles').child(auth.uid).val() === 'owner' && newData.val() !== 'super_owner')
            )"
          }
        },

        // ── Lookup table (username → email mapping) ──────────────────────────
        "lookup": {
          "$username": {
            ".read":  "auth !== null && root.child('tenants').child($tenantId).child('members').child(auth.uid).exists()",
            ".write": "auth !== null && root.child('tenants').child($tenantId).child('members').child(auth.uid).exists()"
          }
        },

        // ── App data (users list, businesses list) ───────────────────────────
        "app": {
          ".read":  "auth !== null && root.child('tenants').child($tenantId).child('members').child(auth.uid).exists()",
          ".write": "auth !== null && root.child('tenants').child($tenantId).child('members').child(auth.uid).exists()"
        },

        // ── All other business data under tenant ─────────────────────────────
        // (biz:xxx:config, biz:xxx:suppliers, etc.)
        "$other": {
          ".read":  "auth !== null && root.child('tenants').child($tenantId).child('members').child(auth.uid).exists()",
          ".write": "auth !== null && root.child('tenants').child($tenantId).child('members').child(auth.uid).exists()"
        }
      }
    }
  }
}
