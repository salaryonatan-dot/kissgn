      ".write": false
    },
    "marjin": {
      ".read": false,
      ".write": false
    },
    "username_index": {
      "$username": {
        ".read": "auth !== null",
        ".write": "auth !== null && (!data.exists() || data.child('email').val() === auth.token.email)",
        ".validate": "newData.hasChildren(['tenantId'])"
      }
    },
    "user_tenants": {
      "$uid": {
        ".read": "auth !== null && auth.uid === $uid",
        ".write": "auth !== null && auth.uid === $uid",
        ".validate": "newData.isString() && newData.val().length < 128"
      }
    },
    "user_active_biz": {
